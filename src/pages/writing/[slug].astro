---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateDisplay = post.data.date.replace(/-/g, '.');
---

<BaseLayout title={post.data.title} description={post.data.subtitle}>
  <div class="page">
    <a href="#main" class="mh-skip">Skip to content</a>

    <header>
      <SiteNav variant="inner" />
    </header>

    <main id="main">
      <article class="article">
        <a href="/writing" class="back">← Writing</a>
        <h1 class="title">{post.data.title}</h1>
        <p class="subtitle">{post.data.subtitle}</p>
        <div class="meta">
          <span>{dateDisplay}</span>
          <span>·</span>
          <span>{post.data.readTime} read</span>
        </div>
        {
          post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          )
        }
        <hr class="divider" />
        <div class="prose"><Content /></div>
        <div class="articleFoot">
          <a href="/writing" class="back">← All posts</a>
        </div>
      </article>
    </main>
  </div>
</BaseLayout>

<style>
  .article {
    max-width: 820px;
    margin: 0 auto;
    padding: 40px 24px 88px;
  }

  .back {
    display: inline-block;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
    margin: 0 0 28px;
  }
  .back:hover {
    color: var(--ink);
    background: transparent;
  }

  .title {
    font-family: var(--serif);
    font-size: clamp(30px, 5vw, 40px);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.01em;
    margin: 0 0 10px;
    max-width: 24ch;
    text-wrap: balance;
    color: var(--ink);
  }

  .subtitle {
    font-size: 18px;
    color: var(--muted);
    margin: 0 0 16px;
    max-width: 60ch;
  }

  .meta {
    display: flex;
    gap: 8px;
    align-items: baseline;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--faint);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 12px 0 0;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--faint);
  }

  .divider {
    border: 0;
    border-top: 1px solid var(--rule);
    margin: 28px 0 32px;
  }

  /* -------------------------------------------------------------- prose */
  .prose {
    max-width: 68ch;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.75;
  }

  .prose :global(h2) {
    font-family: var(--serif);
    font-size: 28px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    margin: 44px 0 12px;
  }

  .prose :global(h3) {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    margin: 30px 0 10px;
  }

  .prose :global(h4) {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--ink);
    margin: 24px 0 8px;
  }

  .prose :global(p) {
    margin: 0 0 18px;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 18px;
    padding-left: 22px;
  }

  .prose :global(li) {
    margin: 0 0 8px;
  }

  .prose :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--faint);
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--rule);
    margin: 0 0 18px;
    padding-left: 16px;
    color: var(--faint);
    font-style: italic;
  }

  .prose :global(code) {
    font-family: var(--mono);
    font-size: 13.5px;
    background: color-mix(in oklab, var(--ink) 6%, var(--bg));
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: 1px 5px;
  }

  .prose :global(pre) {
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.6;
    background: color-mix(in oklab, var(--ink) 5%, var(--bg));
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 14px 16px;
    overflow-x: auto;
    margin: 0 0 18px;
  }

  .prose :global(pre code) {
    background: none;
    border: 0;
    padding: 0;
    font-size: inherit;
  }

  /* GFM tables (now rendered by Astro's markdown pipeline) */
  .prose :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 0 0 18px;
    font-size: 14px;
  }
  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--rule);
    padding: 8px 12px;
    text-align: left;
  }
  .prose :global(th) {
    font-family: var(--mono);
    font-weight: 400;
    color: var(--ink);
  }

  .articleFoot {
    max-width: 68ch;
    margin-top: 52px;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
  }
</style>
